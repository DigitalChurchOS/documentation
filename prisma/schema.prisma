  tenantId      String   @map("tenant_id")
  title         String
  slug          String
  description   String?
  author        String   // iTunes author
  email         String?  // iTunes email
  coverImageUrl String?  @map("cover_image_url")
  category      String   // iTunes category
  subcategory   String?  // iTunes subcategory
  language      String   @default("en")
  link          String?  // website url
  copyright     String?
  explicit      Boolean  @default(false)
  status        String   @default("draft") // draft | published | archived
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  episodes PodcastEpisode[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([status])
  @@map("podcast_shows")
}

// ─────────────────────────────────────────────────────────────
// 67. PODCAST EPISODE
// ─────────────────────────────────────────────────────────────
model PodcastEpisode {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  showId          String   @map("show_id")
  title           String
  slug            String
  description     String?
  audioUrl        String   @map("audio_url")
  durationSeconds Int?     @map("duration_seconds")
  fileSize        Int?     @map("file_size") // in bytes
  mimeType        String   @default("audio/mpeg") @map("mime_type")
  publishDate     DateTime @default(now()) @map("publish_date")
  status          String   @default("draft") // draft | published | archived
  season          Int?
  episodeNumber   Int?     @map("episode_number")
  episodeType     String   @default("full") @map("episode_type") // full | trailer | bonus
  explicit        Boolean  @default(false)
  downloadCount   Int      @default(0) @map("download_count")
  playCount       Int      @default(0) @map("play_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  show   PodcastShow @relation(fields: [showId], references: [id], onDelete: Cascade)

  @@unique([tenantId, showId, slug])
  @@index([tenantId])
  @@index([showId])
  @@index([status])
  @@index([publishDate])
  @@map("podcast_episodes")
}

