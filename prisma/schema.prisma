  currency        String       @default("USD")
  status          String       @default("pending") // pending | processing | completed | shipped | failed
  fulfillmentType String       @map("fulfillment_type") // shipping | pickup
  shippingAddress String?      @map("shipping_address")
  shippingCost    Float        @default(0.0) @map("shipping_cost")
  couponId        String?      @map("coupon_id")
  discountAmount  Float        @default(0.0) @map("discount_amount")
