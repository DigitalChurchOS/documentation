// ─────────────────────────────────────────────────────────────
// 78. DONATION
// ─────────────────────────────────────────────────────────────
model Donation {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  categoryId        String   @map("category_id")
  amount            Float
  currency          String   @default("USD")
  status            String   @default("pending") // pending | succeeded | failed
  paymentMethod     String?  @map("payment_method") // card | bank_transfer | dynamic
  donorName         String?  @map("donor_name")
  donorEmail        String?  @map("donor_email")
  churchServiceId   String?  @map("church_service_id")
  transactionId     String?  @map("transaction_id")
  clientSecret      String?  @map("client_secret")
  recurringGivingId String?  @map("recurring_giving_id")
  campaignId        String?  @map("campaign_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category         GivingCategory   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  recurringGiving  RecurringGiving? @relation(fields: [recurringGivingId], references: [id], onDelete: SetNull)
  campaign         Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([categoryId])
  @@index([recurringGivingId])
  @@index([campaignId])
  @@index([status])
  @@map("donations")
}

