// 93. FINANCIAL TRANSACTION
// ─────────────────────────────────────────────────────────────
model FinancialTransaction {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  accountId   String   @map("account_id")
  type        String   // debit | credit
  amount      Float
  category    String   // tithe | commerce | partnership | utility | payroll | vendor
  reference   String?
  description String
  recordedBy  String   @map("recorded_by")
  recordedAt  DateTime @default(now()) @map("recorded_at")

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([accountId])
  @@map("financial_transactions")
}

// ─────────────────────────────────────────────────────────────
// 94. EXPENSE REQUEST
// ─────────────────────────────────────────────────────────────
model ExpenseRequest {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  accountId   String   @map("account_id")
  budgetId    String?  @map("budget_id")
  requestedBy String   @map("requested_by")
  amount      Float
  category    String
  description String
  status      String   @default("pending") // pending | approved | rejected
  approvedBy  String?  @map("approved_by")
  approvedAt  DateTime? @map("approved_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  budget  FinancialBudget? @relation(fields: [budgetId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([accountId])
  @@index([budgetId])
  @@map("expense_requests")
}

// ─────────────────────────────────────────────────────────────
// 95. RECONCILIATION RECORD
// ─────────────────────────────────────────────────────────────
model ReconciliationRecord {
  id                   String   @id @default(uuid())
  tenantId             String   @map("tenant_id")
  accountId            String   @map("account_id")
  bankStatementBalance Float    @map("bank_statement_balance")
  ledgerBalance        Float    @map("ledger_balance")
  status               String   // matched | discrepancy
  reconciledBy         String   @map("reconciled_by")
  reconciledAt         DateTime @default(now()) @map("reconciled_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([accountId])
  @@map("reconciliation_records")
}

// ─────────────────────────────────────────────────────────────
// 101. MINISTRY FUNNEL
// ─────────────────────────────────────────────────────────────
model MinistryFunnel {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  slug        String
  description String?
  type        String   @default("general") // salvation | new_visitor | event | partnership | course | livestream | general
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  steps       FunnelStep[]
  submissions FunnelSubmission[]
  analytics   FunnelAnalytics[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("ministry_funnels")
}

// ─────────────────────────────────────────────────────────────
// 102. FUNNEL STEP
// ─────────────────────────────────────────────────────────────
model FunnelStep {
  id                 String   @id @default(uuid())
  funnelId           String   @map("funnel_id")
  name               String
  order              Int
  slug               String
  pageId             String?  @map("page_id")
  layoutType         String   @default("landing") @map("layout_type") // landing | form | thank_you | custom
  title              String
  subtitle           String?
  bodyContent        String?  @map("body_content")
  ctaText            String?  @map("cta_text")
  ctaLink            String?  @map("cta_link")
  formConfig         String?  @map("form_config") // JSON array of custom form fields
  countdownEnd       DateTime? @map("countdown_end")
  videoUrl           String?  @map("video_url")
  testimonialText    String?  @map("testimonial_text")
  testimonialAuthor  String?  @map("testimonial_author")
  scriptureReference String?  @map("scripture_reference")
  scriptureText      String?  @map("scripture_text")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  funnel             MinistryFunnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  page               Page?          @relation(fields: [pageId], references: [id], onDelete: SetNull)
  submissions        FunnelSubmission[]
  analytics          FunnelAnalytics[]

  @@unique([funnelId, slug])
  @@index([funnelId])
  @@index([pageId])
  @@map("funnel_steps")
}

// ─────────────────────────────────────────────────────────────
// 103. FUNNEL SUBMISSION
// ─────────────────────────────────────────────────────────────
model FunnelSubmission {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  funnelId      String   @map("funnel_id")
  stepId        String   @map("step_id")
  memberId      String?  @map("member_id")
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  email         String
  phone         String?
  submittedData String   @map("submitted_data") // JSON payload of all fields captured
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  converted     Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  funnel        MinistryFunnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  step          FunnelStep     @relation(fields: [stepId], references: [id], onDelete: Cascade)
  member        Member?        @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([funnelId])
  @@index([stepId])
  @@index([memberId])
  @@map("funnel_submissions")
}

// ─────────────────────────────────────────────────────────────
// 104. FUNNEL ANALYTICS
// ─────────────────────────────────────────────────────────────
model FunnelAnalytics {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  funnelId    String   @map("funnel_id")
  stepId      String   @map("step_id")
  date        DateTime @map("date") // Day-level resolution (YYYY-MM-DD)
  views       Int      @default(0)
  submissions Int      @default(0)

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  funnel      MinistryFunnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  step        FunnelStep     @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([tenantId, funnelId, stepId, date])
  @@index([tenantId])
  @@index([funnelId])
  @@index([stepId])
  @@map("funnel_analytics")
}

// ─────────────────────────────────────────────────────────────
// 105. MEMBER CHECK-IN
// ─────────────────────────────────────────────────────────────
model MemberCheckIn {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  memberId      String   @map("member_id")
  type          String   // service | event | cell | class | other
  targetId      String   @map("target_id")
  checkedInAt   DateTime @default(now()) @map("checked_in_at")
  securityCode  String?  @map("security_code")
  allergies     String?
  checkedInById String?  @map("checked_in_by_id")
  kioskId       String?  @map("kiosk_id")

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([memberId])
  @@map("member_check_ins")
}

// ─────────────────────────────────────────────────────────────
// 106. MEMBER NOTE (Pastoral & Counseling logs)
// ─────────────────────────────────────────────────────────────
model MemberNote {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  memberId  String   @map("member_id")
  authorId  String   @map("author_id")
  noteText  String   @map("note_text")
  category  String   @default("general") // general | counseling | visitation | call | other
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([memberId])
  @@index([authorId])
  @@map("member_notes")
}

// ─────────────────────────────────────────────────────────────
// 107. MEMBER TAG
// ─────────────────────────────────────────────────────────────
model MemberTag {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String   // e.g. "Choir", "Needs Baptism"
  createdAt DateTime @default(now()) @map("created_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments MemberTagAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("member_tags")
}

// ─────────────────────────────────────────────────────────────
// 108. MEMBER TAG ASSIGNMENT (Join Table)
// ─────────────────────────────────────────────────────────────
model MemberTagAssignment {
  id        String   @id @default(uuid())
  memberId  String   @map("member_id")
  tagId     String   @map("tag_id")

  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tag       MemberTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([memberId, tagId])
  @@index([memberId])
  @@index([tagId])
  @@map("member_tag_assignments")
}

// ─────────────────────────────────────────────────────────────
// 109. COMMUNITY POST
// ─────────────────────────────────────────────────────────────
model CommunityPost {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  memberId    String   @map("member_id")
  title       String?
  content     String
  postType    String   @default("discussion") // discussion | announcement | scripture
  visibility  String   @default("public") // public | members_only | group_only
  groupId     String?  @map("group_id") // optional scope to specific cell or team
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  channelId   String?  @map("channel_id")
  channel     CommunityChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  comments    CommunityComment[]
  reactions   CommunityReaction[]

  @@index([tenantId])
  @@index([memberId])
  @@index([groupId])
  @@index([channelId])
  @@map("community_posts")
}

// ─────────────────────────────────────────────────────────────
// 110. PRAYER REQUEST
// ─────────────────────────────────────────────────────────────
model PrayerRequest {
  id                 String    @id @default(uuid())
  tenantId           String    @map("tenant_id")
  memberId           String    @map("member_id")
  title              String
  content            String
  isAnonymous        Boolean   @default(false) @map("is_anonymous")
  visibility         String    @default("public") // public | members_only | pastors_only
  status             String    @default("approved") // pending | approved | answered | followed_up | archived
  prayedCount        Int       @default(0) @map("prayed_count")
  category           String?   // healing | family | salvation | finances | direction
  assignedToId       String?   @map("assigned_to_id")
  followUpReminderAt DateTime? @map("follow_up_reminder_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  assignedTo  Member?  @relation("AssignedPrayers", fields: [assignedToId], references: [id], onDelete: SetNull)
  comments    CommunityComment[]
  reactions   CommunityReaction[]

  @@index([tenantId])
  @@index([memberId])
  @@index([assignedToId])
  @@map("prayer_requests")
}

// ─────────────────────────────────────────────────────────────
// 111. TESTIMONY
// ─────────────────────────────────────────────────────────────
model Testimony {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  memberId    String   @map("member_id")
  title       String
  content     String
  status      String   @default("pending") // pending | approved | rejected
  category    String?  // healing | salvation | provision | protection | family
  mediaUrl    String?  @map("media_url")
  mediaType   String   @default("text") @map("media_type") // text | audio | video
  isFeatured  Boolean  @default(false) @map("is_featured")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  comments    CommunityComment[]
  reactions   CommunityReaction[]

  @@index([tenantId])
  @@index([memberId])
  @@map("testimonies")
}

// ─────────────────────────────────────────────────────────────
// 112. COMMUNITY COMMENT
// ─────────────────────────────────────────────────────────────
model CommunityComment {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  memberId        String   @map("member_id")
  postId          String?  @map("post_id")
  prayerRequestId String?  @map("prayer_request_id")
  testimonyId     String?  @map("testimony_id")
  content         String
  status          String   @default("approved") // pending | approved | spam
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member          Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  post            CommunityPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  prayerRequest   PrayerRequest? @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  testimony       Testimony?     @relation(fields: [testimonyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([memberId])
  @@index([postId])
  @@index([prayerRequestId])
  @@index([testimonyId])
  @@map("community_comments")
}

// ─────────────────────────────────────────────────────────────
// 113. COMMUNITY REACTION
// ─────────────────────────────────────────────────────────────
model CommunityReaction {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  memberId        String   @map("member_id")
  reactionType    String   @map("reaction_type") // e.g. heart | amen | praying_hands
  postId          String?  @map("post_id")
  prayerRequestId String?  @map("prayer_request_id")
  testimonyId     String?  @map("testimony_id")
  createdAt       DateTime @default(now()) @map("created_at")

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member          Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  post            CommunityPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  prayerRequest   PrayerRequest? @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  testimony       Testimony?     @relation(fields: [testimonyId], references: [id], onDelete: Cascade)

  @@unique([memberId, reactionType, postId, prayerRequestId, testimonyId])
  @@index([tenantId])
  @@index([memberId])
  @@index([postId])
  @@index([prayerRequestId])
  @@index([testimonyId])
  @@map("community_reactions")
}

// ═══════════════════════════════════════════════════════════════
// MODULE 29: LIVE CHAT, PASTORAL CARE & SUPPORT
// ═══════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────────
// 29a. CHAT CONVERSATION
// ─────────────────────────────────────────────────────────────
model ChatConversation {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  visitorName     String?   @map("visitor_name")      // for anonymous visitors
  visitorEmail    String?   @map("visitor_email")
  memberId        String?   @map("member_id")         // if identified member
  assignedAgentId String?   @map("assigned_agent_id") // user/staff assigned
  channel         String    @default("website")       // website | livestream | app
  status          String    @default("open")          // open | waiting | assigned | resolved | closed
  priority             String    @default("normal")        // low | normal | high | urgent
  subject              String?
  tags                 String?                              // comma-separated tags e.g. "first_visit,prayer"
  internalNotes        String?   @map("internal_notes")    // private staff notes
  isAnonymous          Boolean   @default(false) @map("is_anonymous")
  departmentId         String?   @map("department_id")
  sentiment            String?             // Distressed, sad, anxious, confused, joyful, neutral
  safetyAlert          Boolean   @default(false) @map("safety_alert")
  aiSuggestedReply     String?   @map("ai_suggested_reply")
  aiSuggestedScriptures String?   @map("ai_suggested_scriptures")
  aiSummary            String?   @map("ai_summary")
  escalatedAt          DateTime? @map("escalated_at")
  resolvedAt           DateTime? @map("resolved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member    Member?        @relation(fields: [memberId], references: [id], onDelete: SetNull)
  messages  ChatMessage[]
  careRequests CareRequest[]
  chatFollowUpTasks ChatFollowUpTask[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([assignedAgentId])
  @@index([memberId])
  @@map("chat_conversations")
}

// ─────────────────────────────────────────────────────────────
// 29b. CHAT MESSAGE
// ─────────────────────────────────────────────────────────────
model ChatMessage {
  id              String   @id @default(uuid())
  conversationId  String   @map("conversation_id")
  senderType      String   @map("sender_type")   // visitor | agent | system
  senderName      String?  @map("sender_name")
  senderId        String?  @map("sender_id")     // userId for agents
  body            String
  messageType     String   @default("text") @map("message_type")  // text | saved_reply | system_event
  isInternal      Boolean  @default(false) @map("is_internal")    // private notes
  audioUrl        String?  @map("audio_url")
  audioDuration   Int?     @map("audio_duration") // in seconds
  transcript      String?
  translatedBody  String?  @map("translated_body")
  translatedLang  String?  @map("translated_lang")
  readAt          DateTime? @map("read_at")
  createdAt       DateTime @default(now()) @map("created_at")

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("chat_messages")
}

// ─────────────────────────────────────────────────────────────
// 29c. CARE REQUEST (pastoral care cases)
// ─────────────────────────────────────────────────────────────
model CareRequest {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  conversationId  String?   @map("conversation_id")
  memberId        String?   @map("member_id")
  requestType     String    @map("request_type")    // prayer | counselling | salvation | testimony | general
  description     String
  status          String    @default("pending")     // pending | assigned | in_progress | resolved | closed
  priority        String    @default("normal")      // low | normal | high | urgent
  assignedAgentId String?   @map("assigned_agent_id")
  resolvedAt      DateTime? @map("resolved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member       Member?           @relation(fields: [memberId], references: [id], onDelete: SetNull)
  conversation ChatConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, requestType])
  @@index([tenantId, status])
  @@index([assignedAgentId])
  @@map("care_requests")
}

// ─────────────────────────────────────────────────────────────
// 29d. SAVED REPLY (pre-written agent responses)
// ─────────────────────────────────────────────────────────────
model SavedReply {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  title     String                        // e.g. "Service Times"
  body      String                        // pre-written response text
  category  String?                       // general | prayer | directions
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("saved_replies")
}

// ─────────────────────────────────────────────────────────────
// 29e. CHAT FOLLOW-UP TASK (tasks created from conversations)
// ─────────────────────────────────────────────────────────────
model ChatFollowUpTask {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  conversationId  String    @map("conversation_id")
  assignedUserId  String?   @map("assigned_user_id")
  title           String
  description     String?
  priority        String    @default("normal")  // low | normal | high | urgent
  status          String    @default("pending") // pending | in_progress | completed
  dueDate         DateTime? @map("due_date")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([conversationId])
  @@index([assignedUserId])
  @@map("chat_follow_up_tasks")
}

// ═══════════════════════════════════════════════════════════════
// MODULE 30: MEMBER OUTREACH & INVITE CAMPAIGN
// ═══════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────────
// 30a. OUTREACH CAMPAIGN
// ─────────────────────────────────────────────────────────────
model OutreachCampaign {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  name          String
  description   String?
  status        String    @default("draft")    // draft | active | paused | completed
  startDate     DateTime? @map("start_date")
  endDate       DateTime? @map("end_date")
  hashtags      String?                         // comma-separated e.g. "#InviteAFriend,#HopeChurch"
  shareCaptions String?   @map("share_captions") // pre-written share text
  ctaLabel      String?   @map("cta_label")     // e.g. "Plan a Visit"
  ctaUrl        String?   @map("cta_url")       // target URL
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant     Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assets     InviteAsset[]
  invitePages PersonalizedInvitePage[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("outreach_campaigns")
}

// ─────────────────────────────────────────────────────────────
// 30b. INVITE ASSET (graphics, videos, downloadables)
// ─────────────────────────────────────────────────────────────
model InviteAsset {
  id          String   @id @default(uuid())
  campaignId  String   @map("campaign_id")
  assetType   String   @map("asset_type")   // image | video | downloadable
  title       String
  url         String                         // CDN / storage URL
  format      String?                        // square | vertical | landscape
  fileSize    Int?     @map("file_size")     // bytes
  createdAt   DateTime @default(now()) @map("created_at")

  campaign OutreachCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("invite_assets")
}

// ─────────────────────────────────────────────────────────────
// 30c. PERSONALIZED INVITE PAGE (per-member unique landing pages)
// ─────────────────────────────────────────────────────────────
model PersonalizedInvitePage {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  campaignId      String    @map("campaign_id")
  memberId        String    @map("member_id")
  slug            String    @unique               // e.g. "invite/grace-adeyemi"
  personalMessage String?   @map("personal_message")
  personalVideoUrl String?  @map("personal_video_url")
  ctaLabel        String?   @map("cta_label")
  clickCount      Int       @default(0) @map("click_count")
  conversionCount Int       @default(0) @map("conversion_count")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign  OutreachCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  member    Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  clicks    InviteLinkClick[]
  shares    ShareEvent[]

  @@index([tenantId])
  @@index([campaignId])
  @@index([memberId])
  @@map("personalized_invite_pages")
}

// ─────────────────────────────────────────────────────────────
// 30d. INVITE LINK CLICK (tracking each click)
// ─────────────────────────────────────────────────────────────
model InviteLinkClick {
  id          String   @id @default(uuid())
  pageId      String   @map("page_id")
  referrer    String?                        // where the click came from
  userAgent   String?  @map("user_agent")
  converted   Boolean  @default(false)       // did they fill out the form?
  createdAt   DateTime @default(now()) @map("created_at")

  page PersonalizedInvitePage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@map("invite_link_clicks")
}

// ─────────────────────────────────────────────────────────────
// 30e. SHARE EVENT (social sharing tracking)
// ─────────────────────────────────────────────────────────────
model ShareEvent {
  id          String   @id @default(uuid())
  pageId      String   @map("page_id")
  platform    String                         // facebook | twitter | whatsapp | copy_link | qr_scan
  createdAt   DateTime @default(now()) @map("created_at")

  page PersonalizedInvitePage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@map("share_events")
}

// ─────────────────────────────────────────────────────────────
// 109. VOLUNTEER WORKFORCE MODELS
// ─────────────────────────────────────────────────────────────

model VolunteerProfile {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  memberId       String   @unique @map("member_id")
  skills         String?  // comma-separated list of skills
  status         String   @default("active") // active | inactive | onboarding
  trainingStatus String   @default("untrained") @map("training_status") // untrained | in_training | certified
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  
  teamAssignments VolunteerTeamAssignment[]
  availabilities  VolunteerAvailability[]
  assignments     VolunteerAssignment[]

  @@index([tenantId])
  @@map("volunteer_profiles")
}

model VolunteerDepartment {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teams  VolunteerTeam[]
  announcements VolunteerAnnouncement[]

  @@index([tenantId])
  @@map("volunteer_departments")
}

model VolunteerTeam {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  departmentId String   @map("department_id")
  name         String
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department VolunteerDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  
  members       VolunteerTeamAssignment[]
  assignments   VolunteerAssignment[]
  announcements VolunteerAnnouncement[]

  @@index([tenantId])
  @@index([departmentId])
  @@map("volunteer_teams")
}

model VolunteerTeamAssignment {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  profileId String   @map("profile_id")
  teamId    String   @map("team_id")
  role      String   @default("volunteer") // leader | assistant | volunteer
  createdAt DateTime @default(now()) @map("created_at")

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile VolunteerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  team    VolunteerTeam    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([profileId, teamId])
  @@index([tenantId])
  @@index([teamId])
  @@map("volunteer_team_assignments")
}

model VolunteerAvailability {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  profileId   String   @map("profile_id")
  blockedDate DateTime @map("blocked_date")
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile VolunteerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, blockedDate])
  @@index([tenantId])
  @@map("volunteer_availabilities")
}

model VolunteerShift {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  title       String
  targetType  String   @map("target_type") // service | event | other
  targetId    String   @map("target_id")
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments VolunteerAssignment[]

  @@index([tenantId])
  @@map("volunteer_shifts")
}

model VolunteerAssignment {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  profileId   String    @map("profile_id")
  teamId      String    @map("team_id")
  shiftId     String    @map("shift_id")
  role        String
  status      String    @default("scheduled") // scheduled | confirmed | declined | checked_in | no_show
  checkedInAt DateTime? @map("checked_in_at")
  taskList    String?   @map("task_list") // JSON string list of checklist items
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile VolunteerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  team    VolunteerTeam    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  shift   VolunteerShift   @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@unique([profileId, shiftId])
  @@index([tenantId])
  @@index([shiftId])
  @@map("volunteer_assignments")
}

model VolunteerAnnouncement {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  teamId       String?  @map("team_id")
  departmentId String?  @map("department_id")
  title        String
  content      String
  sentBy       String   @map("sent_by")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  team       VolunteerTeam?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  department VolunteerDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  sender     User                 @relation(fields: [sentBy], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("volunteer_announcements")
}

// ─────────────────────────────────────────────────────────────
// 110. CUSTOM FORMS & WORKFLOW AUTOMATION
// ─────────────────────────────────────────────────────────────

model CustomForm {
  id                  String   @id @default(uuid())
  tenantId            String   @map("tenant_id")
  title               String
  description         String?
  fields              String   // JSON string representing FormField configs
  confirmationMessage String   @default("Thank you for your submission!") @map("confirmation_message")
  status              String   @default("published") // draft | published | archived
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submissions FormSubmission[]
  triggers    FormWorkflowTrigger[]

  @@index([tenantId])
  @@map("custom_forms")
}

model FormSubmission {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  formId         String   @map("form_id")
  memberId       String?  @map("member_id")
  answers        String   // JSON string of answers
  fileUrl        String?  @map("file_url")
  tags           String?  // comma-separated tags
  approvalStatus String   @default("pending") @map("approval_status") // pending | approved | rejected | not_required
  approvedById   String?  @map("approved_by_id")
  approvalNotes  String?  @map("approval_notes")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  form     CustomForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  member   Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  approver User?   @relation("FormApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([formId])
  @@map("form_submissions")
}

model FormWorkflowTrigger {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  formId         String   @map("form_id")
  triggerType    String   @map("trigger_type") // submission | approval | rejection
  conditionField String?  @map("condition_field")
  conditionValue String?  @map("condition_value")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  form    CustomForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  actions FormWorkflowAction[]

  @@index([tenantId])
  @@index([formId])
  @@map("form_workflow_triggers")
}

model FormWorkflowAction {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  triggerId    String   @map("trigger_id")
  actionType   String   @map("action_type") // send_email | create_task | create_crm_contact | notify_staff
  target       String?  
  templateText String?  @map("template_text")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trigger FormWorkflowTrigger @relation(fields: [triggerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([triggerId])
  @@map("form_workflow_actions")
}

// ─────────────────────────────────────────────────────────────
// 114. PRAYER SESSION (CORPORATE PRAYER)
// ─────────────────────────────────────────────────────────────
model PrayerSession {
  id                   String                       @id @default(uuid())
  tenantId             String                       @map("tenant_id")
  title                String
  description          String?
  leaderId             String?                      @map("leader_id")
  startTime            DateTime                     @map("start_time")
  endTime              DateTime                     @map("end_time")
  recurrence           String?                      // none | daily | weekly | monthly
  musicUrl             String?                      @map("music_url")
  musicVolume          Int                          @default(50) @map("music_volume")
  isMusicPaused        Boolean                      @default(false) @map("is_music_paused")
  isScrollingPaused    Boolean                      @default(false) @map("is_scrolling_paused")
  currentPrayerPointId String?                      @map("current_prayer_point_id")
  status               String                       @default("scheduled") // scheduled | active | completed
  createdAt            DateTime                     @default(now()) @map("created_at")
  updatedAt            DateTime                     @updatedAt @map("updated_at")

  tenant               Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leader               Member?                      @relation("LedSessions", fields: [leaderId], references: [id], onDelete: SetNull)
  participations       PrayerSessionParticipation[]
  prayerPoints         PrayerPoint[]
  reactions            PrayerSessionReaction[]

  @@index([tenantId])
  @@index([leaderId])
  @@map("prayer_sessions")
}

// ─────────────────────────────────────────────────────────────
// 115. PRAYER SESSION PARTICIPATION
// ─────────────────────────────────────────────────────────────
model PrayerSessionParticipation {
  id           String        @id @default(uuid())
  sessionId    String        @map("session_id")
  memberId     String        @map("member_id")
  isPublic     Boolean       @default(true) @map("is_public")
  joinedAt     DateTime      @default(now()) @map("joined_at")
  leftAt       DateTime?     @map("left_at")
  hasConfirmed Boolean       @default(false) @map("has_confirmed")
  audioEnabled Boolean       @default(false) @map("audio_enabled")
  isMuted      Boolean       @default(false) @map("is_muted")
  isTempLeader Boolean       @default(false) @map("is_temp_leader")

  session      PrayerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  member       Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([sessionId, memberId])
  @@index([sessionId])
  @@index([memberId])
  @@map("prayer_session_participations")
}

// ─────────────────────────────────────────────────────────────
// 116. PRAYER POINT
// ─────────────────────────────────────────────────────────────
model PrayerPoint {
  id            String        @id @default(uuid())
  sessionId     String        @map("session_id")
  title         String
  content       String?
  category      String        @default("general") // healing | salvation | family | finances | missions
  duration      Int?          // duration in seconds
  scriptureRef  String?       @map("scripture_ref") // e.g. "Psalm 23:1, John 3:16"
  sequenceOrder Int           @default(0) @map("sequence_order")

  session       PrayerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("prayer_points")
}

// ─────────────────────────────────────────────────────────────
// 117. PRAYER SESSION REACTION
// ─────────────────────────────────────────────────────────────
model PrayerSessionReaction {
  id           String        @id @default(uuid())
  sessionId    String        @map("session_id")
  memberId     String        @map("member_id")
  reactionType String        @map("reaction_type") // amen | praying | praise
  createdAt    DateTime      @default(now()) @map("created_at")

  session      PrayerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  member       Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([memberId])
  @@map("prayer_session_reactions")
}

// ─────────────────────────────────────────────────────────────
// 118. PRAYER MEDIA
// ─────────────────────────────────────────────────────────────
model PrayerMedia {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  title         String
  description   String?
  mediaUrl      String?  @map("media_url")
  mediaType     String   @default("video") @map("media_type") // video | audio | article
  category      String   @default("basics") // basics | intercession | fasting | scripture
  recommendedFor String?  @map("recommended_for") // theme/category keyword
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("prayer_media")
}

// ─────────────────────────────────────────────────────────────
// 119. NEW BELIEVER PROFILE
// ─────────────────────────────────────────────────────────────
model NewBelieverProfile {
  id                        String                @id @default(uuid())
  tenantId                  String                @map("tenant_id")
  memberId                  String                @unique @map("member_id")
  source                    String                // livestream | physical_service | funnel | web
  serviceId                 String?               @map("service_id")
  funnelId                  String?               @map("funnel_id")
  welcomeSentAt             DateTime?             @map("welcome_sent_at")
  followUpStartedAt         DateTime?             @map("follow_up_started_at")
  assignedAgentId           String?               @map("assigned_agent_id")
  cellId                    String?               @map("cell_id")
  bibleReadingPlanStartedAt DateTime?             @map("bible_reading_plan_started_at")
  lmsEnrolledAt             DateTime?             @map("lms_enrolled_at")
  lmsCompletedAt            DateTime?             @map("lms_completed_at")
  isBaptized                Boolean               @default(false) @map("is_baptized")
  joinedGroup               Boolean               @default(false) @map("joined_group")
  finishedClass             Boolean               @default(false) @map("finished_class")
  baptismDate               DateTime?             @map("baptism_date")
