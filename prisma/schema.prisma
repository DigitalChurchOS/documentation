// ─────────────────────────────────────────────────────────────
// 120. NEW BELIEVER REMINDER
// ─────────────────────────────────────────────────────────────
model NewBelieverReminder {
  id           String             @id @default(uuid())
  profileId    String             @map("profile_id")
  reminderType String             @map("reminder_type") // day7 | day30 | custom
  scheduledFor DateTime           @map("scheduled_for")
  completedAt  DateTime?          @map("completed_at")
  status       String             @default("pending") // pending | completed | cancelled
  notes        String?

  profile      NewBelieverProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("new_believer_reminders")
}

// ─────────────────────────────────────────────────────────────
// 121. LMS COURSE
// ─────────────────────────────────────────────────────────────
model LmsCourse {
  id            String          @id @default(uuid())
  tenantId      String          @map("tenant_id")
  title         String
  slug          String
  description   String?
  coverImageUrl String?         @map("cover_image_url")
  status        String          @default("draft") // draft | published | archived
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  modules       LmsModule[]
  enrollments   LmsEnrollment[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("lms_courses")
}

// ─────────────────────────────────────────────────────────────
// 122. LMS MODULE
// ─────────────────────────────────────────────────────────────
model LmsModule {
  id            String      @id @default(uuid())
  tenantId      String      @map("tenant_id")
  courseId      String      @map("course_id")
  title         String
  sequenceOrder Int         @default(0) @map("sequence_order")

  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  course        LmsCourse   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons       LmsLesson[]

  @@index([tenantId])
  @@index([courseId])
  @@map("lms_modules")
}

// ─────────────────────────────────────────────────────────────
// 123. LMS LESSON
// ─────────────────────────────────────────────────────────────
model LmsLesson {
  id            String              @id @default(uuid())
  tenantId      String              @map("tenant_id")
  moduleId      String              @map("module_id")
  title         String
  content       String?
  videoUrl      String?             @map("video_url")
  audioUrl      String?             @map("audio_url")
  pdfUrl        String?             @map("pdf_url")
  sequenceOrder Int                 @default(0) @map("sequence_order")

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module        LmsModule           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  quizzes       LmsQuiz[]
  assignments   LmsAssignment[]
  progress      LmsLessonProgress[]

  @@index([tenantId])
  @@index([moduleId])
  @@map("lms_lessons")
}

// ─────────────────────────────────────────────────────────────
// 124. LMS QUIZ
// ─────────────────────────────────────────────────────────────
model LmsQuiz {
  id            String          @id @default(uuid())
  tenantId      String          @map("tenant_id")
  lessonId      String          @map("lesson_id")
  question      String
  optionsJson   String          @map("options_json")
  correctAnswer String          @map("correct_answer")

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lesson        LmsLesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  answers       LmsQuizAnswer[]

  @@index([tenantId])
  @@index([lessonId])
  @@map("lms_quizzes")
}

// ─────────────────────────────────────────────────────────────
// 125. LMS ASSIGNMENT
// ─────────────────────────────────────────────────────────────
model LmsAssignment {
  id           String                    @id @default(uuid())
  tenantId     String                    @map("tenant_id")
  lessonId     String                    @map("lesson_id")
  title        String
  instructions String?

  tenant       Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lesson       LmsLesson                 @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  submissions  LmsAssignmentSubmission[]

  @@index([tenantId])
  @@index([lessonId])
  @@map("lms_assignments")
}

// ─────────────────────────────────────────────────────────────
// 126. LMS ENROLLMENT
// ─────────────────────────────────────────────────────────────
model LmsEnrollment {
  id                   String                    @id @default(uuid())
  tenantId             String                    @map("tenant_id")
  courseId             String                    @map("course_id")
  memberId             String                    @map("member_id")
  status               String                    @default("enrolled") // enrolled | active | completed
  progressPercent      Float                     @default(0.0) @map("progress_percent")
  completedAt          DateTime?                 @map("completed_at")
  certificateUrl       String?                   @map("certificate_url")
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")

  tenant               Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  course               LmsCourse                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  member               Member                    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  lessonProgress       LmsLessonProgress[]
  quizAnswers          LmsQuizAnswer[]
  assignmentSubmission LmsAssignmentSubmission[]

  @@unique([courseId, memberId])
  @@index([tenantId])
  @@index([courseId])
  @@index([memberId])
  @@map("lms_enrollments")
}

// ─────────────────────────────────────────────────────────────
// 127. LMS LESSON PROGRESS
// ─────────────────────────────────────────────────────────────
model LmsLessonProgress {
  id           String        @id @default(uuid())
  tenantId     String        @map("tenant_id")
  enrollmentId String        @map("enrollment_id")
  lessonId     String        @map("lesson_id")
  isCompleted  Boolean       @default(false) @map("is_completed")
  completedAt  DateTime?     @map("completed_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enrollment   LmsEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson       LmsLesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([tenantId])
  @@index([enrollmentId])
  @@index([lessonId])
  @@map("lms_lesson_progress")
}

// ─────────────────────────────────────────────────────────────
// 128. LMS QUIZ ANSWER
// ─────────────────────────────────────────────────────────────
model LmsQuizAnswer {
  id             String        @id @default(uuid())
  tenantId       String        @map("tenant_id")
  enrollmentId   String        @map("enrollment_id")
  quizId         String        @map("quiz_id")
  selectedAnswer String        @map("selected_answer")
