  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  livestream Livestream? @relation(fields: [livestreamId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("altar_call_responses")
}

// ─────────────────────────────────────────────────────────────
// 44. CENTRALIZED MODULE SETTINGS
// ─────────────────────────────────────────────────────────────
model ModuleSettings {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  moduleKey String   @map("module_key")
  settings  String   @default("{}") // JSON string of settings key-values
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleKey])
  @@index([tenantId])
  @@map("module_settings")
}

// ─────────────────────────────────────────────────────────────
// 45. CMS PAGE REVISIONS
// ─────────────────────────────────────────────────────────────
model PageRevision {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  pageId      String   @map("page_id")
  content     String   // JSON string of page content
  version     Int
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  page      Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdBy User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([pageId])
  @@map("page_revisions")
}

// ─────────────────────────────────────────────────────────────
// 46. NAVIGATION MENU
// ─────────────────────────────────────────────────────────────
model NavigationMenu {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  websiteId String   @map("website_id")
  name      String   // e.g. "Header", "Footer"
  items     String   @default("[]") // JSON string list of links
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([websiteId])
  @@map("navigation_menus")
}

// ─────────────────────────────────────────────────────────────
// 47. CMS FOOTER
// ─────────────────────────────────────────────────────────────
model CmsFooter {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  websiteId      String   @map("website_id")
  copyrightText  String?  @map("copyright_text")
  socialLinks    String   @default("[]") @map("social_links") // JSON string of social media profiles
  secondaryLinks String   @default("[]") @map("secondary_links") // JSON string of footer navigation links
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([websiteId])
  @@map("cms_footers")
}

// ─────────────────────────────────────────────────────────────
// 48. REUSABLE CMS BLOCKS
// ─────────────────────────────────────────────────────────────
model ReusableBlock {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  key       String   // unique label per block
  content   String   // JSON string representing block structure and text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("reusable_blocks")
}

// ─────────────────────────────────────────────────────────────
// 49. CMS ACTIVITY LOGS (AUDIT TRAILS)
// ─────────────────────────────────────────────────────────────
model CmsActivityLog {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  userId       String?  @map("user_id")
  actionType   String   @map("action_type") // page_create | page_update | page_rollback | navigation_update | footer_update
  pageId       String?  @map("page_id")
  metadataJson String   @default("{}") @map("metadata_json") // JSON metadata context
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("cms_activity_logs")
}

// ─────────────────────────────────────────────────────────────
// 50. THEME ENGINE MODULE MODELS
// ─────────────────────────────────────────────────────────────

model ThemeEngineModule {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  title        String   @map("title")
  description  String?
  status       String   @default("active") // active | inactive
  settingsJson String   @default("{}") @map("settings_json")
  visibility   String   @default("public") // public | private
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("theme_engine_module")
}

model ThemeEngineModuleActivity {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  userId       String   @map("user_id")
  actionType   String   @map("action_type") // install | preview | customize | toggle
  metadataJson String   @default("{}") @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("theme_engine_module_activity")
}

model ThemeEngineModuleSettings {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  moduleKey    String   @map("module_key") // theme-engine
  enabled      Boolean  @default(true)
  billingPlan  String   @default("free") @map("billing_plan") // free | premium
  providerMode String   @default("bring_your_own") @map("provider_mode")
  configJson   String   @default("{}") @map("config_json")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleKey])
  @@index([tenantId])
  @@map("theme_engine_module_settings")
}




