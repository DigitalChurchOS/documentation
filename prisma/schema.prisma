generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────────────────────────
// 1. TENANT / CHURCH
// ─────────────────────────────────────────────────────────────
model Tenant {
  id            String   @id @default(uuid())
  name          String                          // Church name
  subdomain     String   @unique               // e.g. "grace"
  customDomain  String?  @unique @map("custom_domain")
  status        String   @default("active")    // active | suspended | trialing
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  branches Branch[]
  users    User[]
  members  Member[]
  roles    Role[]

  connectedServices TenantConnectedService[]
  moduleOverrides   ModuleProviderOverride[]
  tenantModules     TenantModule[]
  themes            Theme[]
  websites          Website[]
  pages             Page[]
  navigationMenus   NavigationMenu[]
  cmsFooters        CmsFooter[]
  reusableBlocks    ReusableBlock[]
  cmsActivityLogs   CmsActivityLog[]
  pageRevisions     PageRevision[]

  families           Family[]
  crmPipelines       CrmPipeline[]
  consentRecords     ConsentRecord[]
  commTemplates      CommunicationTemplate[]
  commLogs           CommunicationLog[]

  subscription       TenantSubscription?
  usageMeters        UsageMeter[]
  invoices           Invoice[]
  analyticsEvents    AnalyticsEvent[]
  installedPlugins   TenantPlugin[]
  pluginWebhooks     PluginWebhook[]

  feedbacks          AssetFeedback[]
  purchases          AssetPurchase[]
  sandboxTenant      SandboxTenant?

  mediaCategories    MediaCategory[]
  mediaTags          MediaTag[]
  speakers           Speaker[]
  mediaSeries        MediaSeries[]
  mediaAssets        MediaAsset[]
  mediaPlaylists     MediaPlaylist[]

  livestreams        Livestream[]
  livestreamChats    LivestreamChat[]
  livestreamViewers  LivestreamViewer[]

  translationJobs      TranslationJob[]
  translatedContents   TranslatedContent[]
  liveTranslationFeeds LiveTranslationFeed[]
  mediaCaptions        MediaCaption[]
  livestreamInteractions LivestreamInteraction[]

  churchServices     ChurchService[]
  blogCategories     BlogCategory[]
  blogTags           BlogTag[]
  blogPosts          BlogPost[]
  blogComments       BlogPostComment[]
  libraryCategories  LibraryCategory[]
  libraryResources   LibraryResource[]
  libraryPurchases   LibraryPurchase[]
  podcastShows       PodcastShow[]
  podcastEpisodes    PodcastEpisode[]
  aiMediaJobs        AiMediaJob[]
  aiAssistantJobs    AiAssistantJob[]
  displayScreens     DisplayScreen[]
  agentPresences      AgentPresence[]
  communityChannels   CommunityChannel[]
  chatKbArticles      ChatKbArticle[]
  altarCallResponses  AltarCallResponse[]
  moduleSettings      ModuleSettings[]
  signagePlaylists   SignagePlaylist[]
  signageSlides      SignageSlide[]
  worshipSongs       WorshipSong[]
  worshipPlaylists   WorshipPlaylist[]
  worshipSessions    WorshipSession[]
  givingCategories   GivingCategory[]
  donations          Donation[]
  recurringGivings   RecurringGiving[]
  partnershipCategories PartnershipCategory[]
  partnerships          Partnership[]
  recurringPartnerships RecurringPartnership[]
  campaigns             Campaign[]
  campaignUpdates       CampaignUpdate[]
  productCategories     ProductCategory[]
  products              Product[]
  productVariants       ProductVariant[]
  storeCoupons          StoreCoupon[]
  storeOrders           StoreOrder[]
  orderItems            OrderItem[]
  financialAccounts     FinancialAccount[]
  financialBudgets      FinancialBudget[]
  financialTransactions FinancialTransaction[]
  expenseRequests       ExpenseRequest[]
  reconciliationRecords ReconciliationRecord[]
  ministryFunnels       MinistryFunnel[]
  funnelSubmissions     FunnelSubmission[]
  funnelAnalytics       FunnelAnalytics[]
  memberCheckIns        MemberCheckIn[]
  memberNotes           MemberNote[]
  memberTags            MemberTag[]
  communityPosts        CommunityPost[]
  prayerRequests        PrayerRequest[]
  testimonies           Testimony[]
  communityComments     CommunityComment[]
  communityReactions    CommunityReaction[]
  crmContacts           CrmContact[]
  crmTimelineEvents     CrmTimelineEvent[]
  crmFollowUpTasks      CrmFollowUpTask[]
  notificationPrefs     NotificationPreference[]
  scheduledMessages     ScheduledMessage[]
  automationWorkflows   AutomationWorkflow[]
  followUpSequences     FollowUpSequence[]
  chatConversations     ChatConversation[]
  careRequests          CareRequest[]
  savedReplies          SavedReply[]
  chatFollowUpTasks     ChatFollowUpTask[]
  outreachCampaigns     OutreachCampaign[]
  personalizedInvitePages PersonalizedInvitePage[]

  volunteerProfiles        VolunteerProfile[]
  volunteerDepartments     VolunteerDepartment[]
  volunteerTeams           VolunteerTeam[]
  volunteerTeamAssignments VolunteerTeamAssignment[]
  volunteerAvailabilities  VolunteerAvailability[]
  volunteerShifts          VolunteerShift[]
  volunteerAssignments     VolunteerAssignment[]
  volunteerAnnouncements   VolunteerAnnouncement[]

  customForms              CustomForm[]
  formSubmissions          FormSubmission[]
  formWorkflowTriggers     FormWorkflowTrigger[]
  formWorkflowActions      FormWorkflowAction[]
  prayerSessions           PrayerSession[]
  prayerMedia              PrayerMedia[]
  newBelieverProfiles      NewBelieverProfile[]
  lmsCourses               LmsCourse[]
  lmsModules               LmsModule[]
  lmsLessons               LmsLesson[]
  lmsQuizzes               LmsQuiz[]
  lmsAssignments           LmsAssignment[]
  lmsEnrollments           LmsEnrollment[]
  lmsLessonProgress        LmsLessonProgress[]
  lmsQuizAnswers           LmsQuizAnswer[]
  lmsAssignmentSubmissions LmsAssignmentSubmission[]
  bibleTranslations           BibleTranslation[]
  bibleBooks                  BibleBook[]
  bibleVerses                 BibleVerse[]
  bibleReadingPlans           BibleReadingPlan[]
  bibleReadingPlanDays        BibleReadingPlanDay[]
  bibleReadingPlanEnrollments BibleReadingPlanEnrollment[]
  bibleBookmarks              BibleBookmark[]
  bibleVerseNotes             BibleVerseNote[]
  dailyDevotionals            DailyDevotional[]
  bibleVerseHighlights        BibleVerseHighlight[]
  bibleAudioTracks            BibleAudioTrack[]

  groups                 Group[]
  groupTypes             GroupType[]
  groupMembers           GroupMember[]
  groupMeetings          GroupMeeting[]
  groupAttendances       GroupAttendance[]
  groupInviteLinks       GroupInviteLink[]
  groupInviteConversions GroupInviteConversion[]
  groupNoticeBoards      GroupNoticeBoard[]
  groupNoticePosts       GroupNoticePost[]
  groupPromotions        GroupPromotion[]
  groupSettings          GroupSettings[]

  childProfiles             ChildProfile[]
  childGuardians            ChildGuardian[]
  pickupAuthorizations      PickupAuthorization[]
  childrenClasses           ChildrenClass[]
  childrenClassEnrollments  ChildrenClassEnrollment[]
  childrenClassResources    ChildrenClassResource[]
  childrenCheckIns          ChildrenCheckIn[]

  eventCategories        EventCategory[]
  events                 Event[]
  eventRegistrations     EventRegistration[]
  eventTickets           EventTicket[]
  eventRsvps             EventRsvp[]
  eventReminders         EventReminder[]

  liveMeetings           LiveMeeting[]
  liveMeetingParticipants LiveMeetingParticipant[]
  liveMeetingChats       LiveMeetingChat[]
  liveMeetingAttendances LiveMeetingAttendance[]
  liveMeetingReminders   LiveMeetingReminder[]

  appointmentTypes       AppointmentType[]
  staffAvailabilities   StaffAvailability[]
  appointments           Appointment[]
  appointmentReminders   AppointmentReminder[]
  mobilePushTokens       MobilePushToken[]

  whiteLabelApp          WhiteLabelApp?
  whiteLabelBuilds       WhiteLabelBuild[]

  branchRegions          BranchRegion[]
  branchLeaders          BranchLeader[]

  themeEngineModules     ThemeEngineModule[]
  themeEngineActivities  ThemeEngineModuleActivity[]
  themeEngineSettings    ThemeEngineModuleSettings[]

  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────
// 2. BRANCH / CAMPUS
// ─────────────────────────────────────────────────────────────
model Branch {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  name           String                               // e.g. "Downtown Campus"
  timezone       String   @default("UTC")
  status         String   @default("active")          // active | inactive
  description    String?                               // campus description
  address        String?                               // street address
  city           String?
  state          String?
  country        String?
  postalCode     String?  @map("postal_code")
  phone          String?
  email          String?
  logoUrl        String?  @map("logo_url")            // branch-specific logo
  coverImageUrl  String?  @map("cover_image_url")     // branch cover image
  regionId       String?  @map("region_id")           // link to regional grouping
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  region             BranchRegion?   @relation(fields: [regionId], references: [id], onDelete: SetNull)
  displayScreens     DisplayScreen[]
  financialAccounts  FinancialAccount[]
  financialBudgets   FinancialBudget[]
  branchLeaders      BranchLeader[]
  members            Member[]        @relation("BranchMembers")

  @@index([tenantId])
  @@index([regionId])
  @@map("branches")
}

// ─────────────────────────────────────────────────────────────
// 2b. BRANCH REGION (geographic grouping)
// ─────────────────────────────────────────────────────────────
model BranchRegion {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String                                 // e.g. "North America", "Europe"
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branches Branch[]

  @@index([tenantId])
  @@map("branch_regions")
}

// ─────────────────────────────────────────────────────────────
// 2c. BRANCH LEADER (leadership assignment)
// ─────────────────────────────────────────────────────────────
model BranchLeader {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  branchId  String   @map("branch_id")
  userId    String   @map("user_id")
  role      String                                   // branch_pastor | branch_admin | branch_coordinator
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([branchId, userId])
  @@index([tenantId])
  @@index([branchId])
  @@index([userId])
  @@map("branch_leaders")
}

// ─────────────────────────────────────────────────────────────
// 3. USER  (security / login identity)
// ─────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  email        String                            // login email
  passwordHash String   @map("password_hash")
  status       String   @default("active")       // active | invited | blocked
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member    Member?                              // optional linked profile
  userRoles UserRole[]
  crmStages MemberCrmStage[]
  developerProfile DeveloperProfile?
  preferredLanguage String   @default("en") @map("preferred_language")
  blogComments      BlogPostComment[]
  libraryPurchases  LibraryPurchase[]
  memberNotes       MemberNote[]
  volunteerAnnouncements VolunteerAnnouncement[]
  approvedSubmissions    FormSubmission[]        @relation("FormApprover")
  checkedInAttendances   GroupAttendance[]
  groupNoticePosts       GroupNoticePost[]
  approvedPromotions     GroupPromotion[]
  mobilePushTokens       MobilePushToken[]
  branchLeaderAssignments BranchLeader[]
  agentPresence          AgentPresence?
  pageRevisions          PageRevision[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// 4. MEMBER  (congregation profile)
// ─────────────────────────────────────────────────────────────
model Member {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  userId           String?  @unique @map("user_id") // link to User (optional)
  familyId         String?  @map("family_id")       // household link (optional)
  familyRole       String?  @map("family_role")     // e.g. head, spouse, child, other
  firstName        String   @map("first_name")
  lastName         String   @map("last_name")
  phone            String?
  email            String?
  photoUrl         String?  @map("photo_url")
  gender           String?
  birthday         DateTime?
  address          String?
  emergencyContact String?  @map("emergency_contact")
  membershipStatus String   @default("visitor") @map("membership_status") // visitor | member | leader
  branchId         String?  @map("branch_id")    // campus/branch assignment
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  family Family? @relation(fields: [familyId], references: [id], onDelete: SetNull)
  branch Branch? @relation("BranchMembers", fields: [branchId], references: [id], onDelete: SetNull)

  crmStages         MemberCrmStage[]
  consentRecords    ConsentRecord[]
  communicationLogs CommunicationLog[]
  preferredLanguage String   @default("en") @map("preferred_language")
  funnelSubmissions FunnelSubmission[]
  checkIns          MemberCheckIn[]
  notes             MemberNote[]
  tagAssignments    MemberTagAssignment[]
  communityPosts    CommunityPost[]
  prayerRequests    PrayerRequest[]
  testimonies       Testimony[]
  communityComments CommunityComment[]
  communityReactions CommunityReaction[]
  crmContacts        CrmContact[]
  notificationPref   NotificationPreference?
  chatConversations  ChatConversation[]
  careRequests       CareRequest[]
  personalizedInvitePages PersonalizedInvitePage[]
  volunteerProfile   VolunteerProfile?
  formSubmissions    FormSubmission[]
  ledSessions        PrayerSession[]           @relation("LedSessions")
  participations     PrayerSessionParticipation[]
  sessionReactions   PrayerSessionReaction[]
  assignedPrayers    PrayerRequest[]           @relation("AssignedPrayers")
  newBelieverProfile NewBelieverProfile?
  convertsAssigned   NewBelieverProfile[]      @relation("AgentConverts")
  lmsEnrollments     LmsEnrollment[]
  gradedSubmissions  LmsAssignmentSubmission[] @relation("GradedSubmissions")
  bibleReadingPlanEnrollments BibleReadingPlanEnrollment[]
  bibleBookmarks               BibleBookmark[]
  bibleVerseNotes              BibleVerseNote[]
  authoredDevotionals          DailyDevotional[]
  bibleVerseHighlights         BibleVerseHighlight[]
  ledGroups                    Group[]                   @relation("GroupLeader")
  coLedGroups                  Group[]                   @relation("GroupCoLeader")
  hostedGroups                 Group[]                   @relation("GroupHost")
  groupMemberships             GroupMember[]
  groupAttendances             GroupAttendance[]
  groupInviteLinks             GroupInviteLink[]
  groupInviteConversions       GroupInviteConversion[]

  childProfile                 ChildProfile?
  childGuardianships           ChildGuardian[]           @relation("GuardianMember")
  childrenCheckedIn            ChildrenCheckIn[]         @relation("ChildCheckedInBy")
  childrenCheckedOut           ChildrenCheckIn[]         @relation("ChildCheckedOutBy")

  eventRegistrations           EventRegistration[]
  eventRsvps                   EventRsvp[]

  hostedMeetings               LiveMeeting[]             @relation("MeetingHost")
  meetingParticipations       LiveMeetingParticipant[]

  staffAvailabilities          StaffAvailability[]
  hostedAppointments           Appointment[]             @relation("AppointmentHost")
  bookedAppointments           Appointment[]             @relation("AppointmentBooker")

  @@index([tenantId])
  @@index([familyId])
  @@index([branchId])
  @@map("members")
}

// ─────────────────────────────────────────────────────────────
// 5. ROLE
// ─────────────────────────────────────────────────────────────
model Role {
  id          String   @id @default(uuid())
  tenantId    String?  @map("tenant_id")         // null = system-wide role
  name        String                              // e.g. "Owner", "Pastor", "Finance"
  description String?
  isCustom    Boolean  @default(true) @map("is_custom")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([tenantId])
  @@map("roles")
}

// ─────────────────────────────────────────────────────────────
// 6. PERMISSION  (platform-wide capability keys)
// ─────────────────────────────────────────────────────────────
model Permission {
  id          String @id @default(uuid())
  name        String @unique                     // e.g. "member.read", "member.create"
  description String?

  rolePermissions RolePermission[]

  @@map("permissions")
}

// ─────────────────────────────────────────────────────────────
// 7. ROLE ↔ PERMISSION  (join table)
// ─────────────────────────────────────────────────────────────
model RolePermission {
  id           String @id @default(uuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ─────────────────────────────────────────────────────────────
// 8. USER ↔ ROLE  (join table)
// ─────────────────────────────────────────────────────────────
model UserRole {
  id     String @id @default(uuid())
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

// ─────────────────────────────────────────────────────────────
// 9. PROVIDER CATEGORY
// ─────────────────────────────────────────────────────────────
model ProviderCategory {
  id        String   @id // e.g. "payment", "sms", "media_storage"
  name      String   // e.g. "Payment Gateway", "SMS Gateway"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  providers                Provider[]
  moduleProviderOverrides ModuleProviderOverride[]

  @@map("provider_categories")
}

// ─────────────────────────────────────────────────────────────
// 10. PROVIDER
// ─────────────────────────────────────────────────────────────
model Provider {
  id         String   @id // e.g. "stripe", "paystack", "twilio"
  categoryId String   @map("category_id")
  name       String   // e.g. "Stripe", "Twilio"
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category                ProviderCategory         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tenantConnectedServices TenantConnectedService[]

  @@index([categoryId])
  @@map("providers")
}

// ─────────────────────────────────────────────────────────────
// 11. TENANT CONNECTED SERVICE
// ─────────────────────────────────────────────────────────────
model TenantConnectedService {
  id                   String   @id @default(uuid())
  tenantId             String   @map("tenant_id")
  providerId           String   @map("provider_id")
  encryptedCredentials String   @map("encrypted_credentials") // AES-256 encrypted JSON config
  providerMode         String   @default("bring_your_own") @map("provider_mode") // platform_managed | bring_your_own
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  moduleProviderOverrides ModuleProviderOverride[]

  @@unique([tenantId, providerId])
  @@index([tenantId])
  @@index([providerId])
  @@map("tenant_connected_services")
}

// ─────────────────────────────────────────────────────────────
// 12. MODULE PROVIDER OVERRIDE
// ─────────────────────────────────────────────────────────────
model ModuleProviderOverride {
  id                 String   @id @default(uuid())
  tenantId           String   @map("tenant_id")
  moduleKey          String   @map("module_key") // e.g. "website-cms", "salvation-journey"
  categoryId         String   @map("category_id")
  connectedServiceId String   @map("connected_service_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category         ProviderCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  connectedService TenantConnectedService @relation(fields: [connectedServiceId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleKey, categoryId])
  @@index([tenantId])
  @@index([categoryId])
  @@index([connectedServiceId])
  @@map("module_provider_overrides")
}

// ─────────────────────────────────────────────────────────────
// 13. MODULE DEFINITION
// ─────────────────────────────────────────────────────────────
model ModuleDefinition {
  key          String   @id // e.g. "website-cms", "media-sermons"
  name         String
  category     String
  dependencies String   @default("[]") // JSON string array of dependency keys
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenantModules TenantModule[]

  @@map("module_definitions")
}

// ─────────────────────────────────────────────────────────────
// 14. TENANT MODULE  (subscription check)
// ─────────────────────────────────────────────────────────────
model TenantModule {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  moduleKey   String   @map("module_key")
  status      String   @default("active") // pending | active | suspended | trialing
  billingRule String   @default("free") @map("billing_rule") // free | flat_rate | tiered
  usageLimits String   @default("{}") @map("usage_limits") // JSON object settings
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module ModuleDefinition @relation(fields: [moduleKey], references: [key], onDelete: Cascade)

  @@unique([tenantId, moduleKey])
  @@index([tenantId])
  @@index([moduleKey])
  @@map("tenant_modules")
}

// ─────────────────────────────────────────────────────────────
// 15. THEME  (visual stylesheet vars)
// ─────────────────────────────────────────────────────────────
model Theme {
  id        String   @id @default(uuid())
  tenantId  String?  @map("tenant_id") // null = global platform system theme
  name      String
  settings  String   @default("{}") // JSON string of custom color palettes and fonts
  isCustom  Boolean  @default(true) @map("is_custom")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  websites Website[]

  @@index([tenantId])
  @@map("themes")
}

// ─────────────────────────────────────────────────────────────
// 16. WEBSITE
// ─────────────────────────────────────────────────────────────
model Website {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  themeId     String   @map("theme_id")
  title       String
  description String?
  domain      String?  @unique // custom domain lookup
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  theme  Theme  @relation(fields: [themeId], references: [id], onDelete: Restrict)

  pages           Page[]
  navigationMenus NavigationMenu[]
  cmsFooters      CmsFooter[]

  @@index([tenantId])
  @@index([themeId])
  @@map("websites")
}

// ─────────────────────────────────────────────────────────────
// 17. PAGE  (CMS content block structure)
// ─────────────────────────────────────────────────────────────
model Page {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  websiteId      String   @map("website_id")
  slug           String // e.g. "about", "give" (home is "")
  title          String
  content        String   @default("[]") // JSON string array of layouts and content blocks
  status         String   @default("draft") // draft | published
  isHome         Boolean  @default(false) @map("is_home")
  seoTitle       String?  @map("seo_title")
  seoDescription String?  @map("seo_description")
  seoKeywords    String?  @map("seo_keywords")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  funnelSteps FunnelStep[]
  revisions   PageRevision[]

  @@unique([websiteId, slug])
  @@index([tenantId])
  @@index([websiteId])
  @@map("pages")
}

// ─────────────────────────────────────────────────────────────
// 18. FAMILY / HOUSEHOLD
// ─────────────────────────────────────────────────────────────
model Family {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String   // e.g. "The Smith Household"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members Member[]

  @@index([tenantId])
  @@map("families")
}

// ─────────────────────────────────────────────────────────────
// 19. CRM PIPELINE
// ─────────────────────────────────────────────────────────────
model CrmPipeline {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String   // e.g. "New Visitor Follow-up"
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages CrmStage[]

  @@index([tenantId])
  @@map("crm_pipelines")
}

// ─────────────────────────────────────────────────────────────
// 20. CRM STAGE
// ─────────────────────────────────────────────────────────────
model CrmStage {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  pipelineId String   @map("pipeline_id")
  name       String   // e.g. "Called", "Assigned Fellowship"
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  pipeline        CrmPipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  memberCrmStages MemberCrmStage[]

  @@index([tenantId])
  @@index([pipelineId])
  @@map("crm_stages")
}

// ─────────────────────────────────────────────────────────────
// 21. MEMBER CRM STAGE  (active stage position)
// ─────────────────────────────────────────────────────────────
model MemberCrmStage {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  memberId       String   @map("member_id")
  stageId        String   @map("stage_id")
  status         String   @default("active") // active | completed | dropped
  assignedUserId String?  @map("assigned_user_id") // caretaker admin user
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  member       Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  stage        CrmStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  assignedUser User?  @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([memberId])
  @@index([stageId])
  @@index([assignedUserId])
  @@map("member_crm_stages")
}

// ─────────────────────────────────────────────────────────────
// 21b. CRM CONTACT  (visitor / lead / external vendor profile)
// ─────────────────────────────────────────────────────────────
model CrmContact {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  memberId        String?  @map("member_id")         // linked member (optional; null = pure lead)
  firstName       String   @map("first_name")
  lastName        String   @map("last_name")
  email           String?
  phone           String?
  type            String   @default("visitor")       // visitor | lead | vendor | partner
  leadSource      String?  @map("lead_source")       // facebook | google_ad | invite_link | walk_in | website | referral | event
  leadSourceDetail String?  @map("lead_source_detail") // e.g. campaign name, referrer name
  status          String   @default("new")           // new | contacted | engaged | converted | inactive
  engagementScore Int      @default(0) @map("engagement_score")
  notes           String?
  firstContactAt  DateTime? @map("first_contact_at")
  lastContactAt   DateTime? @map("last_contact_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member    Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  timeline  CrmTimelineEvent[]
  tasks     CrmFollowUpTask[]

  @@index([tenantId])
  @@index([memberId])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@map("crm_contacts")
}

// ─────────────────────────────────────────────────────────────
// 21c. CRM TIMELINE EVENT  (unified activity feed per contact)
// ─────────────────────────────────────────────────────────────
model CrmTimelineEvent {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  contactId   String   @map("contact_id")
  type        String                                // email_sent | sms_sent | call | note | stage_change | event_attended | form_submitted | salvation_response | course_enrolled | check_in | giving
  title       String
  description String?
  metadata    String?                               // JSON string for extra structured data
  occurredAt  DateTime @default(now()) @map("occurred_at")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant  Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([contactId])
  @@index([contactId, occurredAt])
  @@map("crm_timeline_events")
}

// ─────────────────────────────────────────────────────────────
// 21d. CRM FOLLOW-UP TASK  (task assignment & reminders)
// ─────────────────────────────────────────────────────────────
model CrmFollowUpTask {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  contactId       String    @map("contact_id")
  assignedUserId  String?   @map("assigned_user_id")
  title           String
  description     String?
  priority        String    @default("normal")       // low | normal | high | urgent
  status          String    @default("pending")      // pending | in_progress | completed | cancelled
  dueDate         DateTime? @map("due_date")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact      CrmContact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([contactId])
  @@index([assignedUserId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@map("crm_followup_tasks")
}

// ─────────────────────────────────────────────────────────────
// 22. CONSENT RECORD  (GDPR/TCPA privacy compliance gates)
// ─────────────────────────────────────────────────────────────
model ConsentRecord {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  memberId     String   @map("member_id")
  optInSms     Boolean  @default(true) @map("opt_in_sms")
  optInEmail   Boolean  @default(true) @map("opt_in_email")
  gdprConsent  Boolean  @default(true) @map("gdpr_consent")
  recordedAt   DateTime @default(now()) @map("recorded_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId])
  @@index([tenantId])
  @@index([memberId])
  @@map("consent_records")
}

// ─────────────────────────────────────────────────────────────
// 23. COMMUNICATION TEMPLATE
// ─────────────────────────────────────────────────────────────
model CommunicationTemplate {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String   // e.g. "Welcome SMS"
  type      String   // sms | email
  subject   String?  // for email only
  body      String   // message body with placeholders e.g. Hello {{first_name}}
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  communicationLogs CommunicationLog[]

  @@index([tenantId])
  @@map("communication_templates")
}

// ─────────────────────────────────────────────────────────────
// 24. COMMUNICATION LOG  (dispatch tracking)
// ─────────────────────────────────────────────────────────────
model CommunicationLog {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  memberId   String    @map("member_id")
  templateId String?   @map("template_id")
  type       String    // sms | email
  recipient  String    // e.g. phone or email address
  subject    String?   // email subject
  body       String    // compiled content text
  status     String    @default("pending") // pending | sent | failed | opted_out
  errorMsg   String?   @map("error_msg")
  sentAt     DateTime? @map("sent_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant   Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member   Member                 @relation(fields: [memberId], references: [id], onDelete: Cascade)
  template CommunicationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([memberId])
  @@index([templateId])
  @@map("communication_logs")
}

// ─────────────────────────────────────────────────────────────
// 24b. NOTIFICATION PREFERENCE (per-member channel preferences)
// ─────────────────────────────────────────────────────────────
model NotificationPreference {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  memberId          String   @unique @map("member_id")
  preferEmail       Boolean  @default(true) @map("prefer_email")
  preferSms         Boolean  @default(false) @map("prefer_sms")
  preferPush        Boolean  @default(true) @map("prefer_push")
  preferWhatsapp    Boolean  @default(false) @map("prefer_whatsapp")
  quietHoursStart   String?  @map("quiet_hours_start")  // e.g. "22:00"
  quietHoursEnd     String?  @map("quiet_hours_end")    // e.g. "07:00"
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("notification_preferences")
}

// ─────────────────────────────────────────────────────────────
// 24c. SCHEDULED MESSAGE (future-dated communications)
// ─────────────────────────────────────────────────────────────
model ScheduledMessage {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  templateId    String    @map("template_id")
  audienceType  String    @default("all") @map("audience_type")  // all | segment | individual
  audienceFilter String?  @map("audience_filter")  // JSON filter criteria or memberId
  scheduledAt   DateTime  @map("scheduled_at")
  status        String    @default("pending")      // pending | sent | cancelled | failed
  sentAt        DateTime? @map("sent_at")
  errorMsg      String?   @map("error_msg")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([scheduledAt])
  @@map("scheduled_messages")
}

// ─────────────────────────────────────────────────────────────
// 24d. AUTOMATION WORKFLOW (event-triggered automations)
// ─────────────────────────────────────────────────────────────
model AutomationWorkflow {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  name          String
  triggerEvent  String    @map("trigger_event")  // member.created | event.registered | salvation.response | form.submitted | check_in.recorded
  templateId    String    @map("template_id")
  channel       String    @default("email")      // email | sms | push | whatsapp
  delayMinutes  Int       @default(0) @map("delay_minutes")  // delay after trigger
  isActive      Boolean   @default(true) @map("is_active")
  executionCount Int      @default(0) @map("execution_count")
  lastExecutedAt DateTime? @map("last_executed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, triggerEvent])
  @@map("automation_workflows")
}

// ─────────────────────────────────────────────────────────────
// 24e. FOLLOW-UP SEQUENCE (multi-step drip campaigns)
// ─────────────────────────────────────────────────────────────
model FollowUpSequence {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  triggerEvent String  @map("trigger_event")   // e.g. "first_visit" | "salvation_response"
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  steps  FollowUpStep[]

  @@index([tenantId])
  @@map("follow_up_sequences")
}

// ─────────────────────────────────────────────────────────────
// 24f. FOLLOW-UP STEP (individual step in a drip sequence)
// ─────────────────────────────────────────────────────────────
model FollowUpStep {
  id          String   @id @default(uuid())
  sequenceId  String   @map("sequence_id")
  templateId  String   @map("template_id")
  channel     String   @default("email")   // email | sms
  delayDays   Int      @map("delay_days")  // days after trigger to send
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  sequence FollowUpSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
  @@map("follow_up_steps")
}

// ─────────────────────────────────────────────────────────────
// 25. SUBSCRIPTION PLAN
// ─────────────────────────────────────────────────────────────
model SubscriptionPlan {
  id                 String   @id @default(uuid())
  name               String   // e.g. "Free", "Growth", "Enterprise"
  basePrice          Float    @map("base_price") // base monthly fee
  includedMembers    Int      @map("included_members")
  includedSms        Int      @map("included_sms")
  includedStorageGb  Float    @map("included_storage_gb")
  memberOverageRate  Float    @map("member_overage_rate")
  smsOverageRate     Float    @map("sms_overage_rate")
  storageOverageRate Float    @map("storage_overage_rate")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  subscriptions TenantSubscription[]

  @@map("subscription_plans")
}

// ─────────────────────────────────────────────────────────────
// 26. TENANT SUBSCRIPTION
// ─────────────────────────────────────────────────────────────
model TenantSubscription {
  id                String   @id @default(uuid())
  tenantId          String   @unique @map("tenant_id")
  planId            String   @map("plan_id")
  status            String   @default("active") // active | suspended | trialing | unpaid
  trialEndsAt       DateTime? @map("trial_ends_at")
  currentPeriodStart DateTime @map("current_period_start")
  currentPeriodEnd   DateTime @map("current_period_end")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([tenantId])
  @@index([planId])
  @@map("tenant_subscriptions")
}

// ─────────────────────────────────────────────────────────────
// 27. USAGE METER
// ─────────────────────────────────────────────────────────────
model UsageMeter {
  id                 String   @id @default(uuid())
  tenantId           String   @map("tenant_id")
  metricKey          String   @map("metric_key") // active_members | sms_sent | storage_gb | ai_tokens | meeting_hours
  quantity           Float    @default(0)
  billingPeriodStart DateTime @map("billing_period_start")
  billingPeriodEnd   DateTime @map("billing_period_end")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, metricKey, billingPeriodStart, billingPeriodEnd])
  @@index([tenantId])
  @@map("usage_meters")
}

// ─────────────────────────────────────────────────────────────
// 28. INVOICE
// ─────────────────────────────────────────────────────────────
model Invoice {
  id                 String   @id @default(uuid())
  tenantId           String   @map("tenant_id")
  amount             Float
  status             String   @default("open") // paid | open | void
  billingPeriodStart DateTime @map("billing_period_start")
  billingPeriodEnd   DateTime @map("billing_period_end")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("invoices")
}

// ─────────────────────────────────────────────────────────────
// 29. ANALYTICS EVENT
// ─────────────────────────────────────────────────────────────
model AnalyticsEvent {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  category  String   // website | media | livestream | giving | outreach | crm | salvation | lms
  name      String   // page_view | play | attend | donate | click | check_in | response
  entityId  String?  @map("entity_id") // UUID of referenced entity
  value     Float?   // quantity e.g. duration, donation amount, count
  userId    String?  @map("user_id") // associated user if authenticated
  sessionId String?  @map("session_id") // guest session tracking identifier
  metadata  String   @default("{}") // JSON string of custom tags/details
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([category, name])
  @@index([createdAt])
  @@map("analytics_events")
}

// ─────────────────────────────────────────────────────────────
// 30. PLUGIN DEFINITION
// ─────────────────────────────────────────────────────────────
model PluginDefinition {
  id                  String   @id // e.g. "whatsapp-gateway"
  name                String
  description         String?
  version             String   @default("1.0.0")
  requiredPermissions String   @default("[]") @map("required_permissions") // JSON string array
  requiredOsVersion   String   @default("1.0.0") @map("required_os_version")
  price               Float    @default(0.0)
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tenantPlugins TenantPlugin[]

  @@map("plugin_definitions")
}

// ─────────────────────────────────────────────────────────────
// 31. TENANT INSTALLED PLUGIN
// ─────────────────────────────────────────────────────────────
model TenantPlugin {
  id                 String   @id @default(uuid())
  tenantId           String   @map("tenant_id")
  pluginId           String   @map("plugin_id")
  status             String   @default("active") // active | inactive | pending
  settings           String   @default("{}") // JSON settings injected by the plugin
  grantedPermissions String   @default("[]") @map("granted_permissions") // JSON array of granted scopes
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plugin PluginDefinition @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  webhooks PluginWebhook[]

  @@unique([tenantId, pluginId])
  @@index([tenantId])
  @@index([pluginId])
  @@map("tenant_plugins")
}

// ─────────────────────────────────────────────────────────────
// 32. PLUGIN WEBHOOK
// ─────────────────────────────────────────────────────────────
model PluginWebhook {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  tenantPluginId String   @map("tenant_plugin_id")
  eventTrigger   String   @map("event_trigger") // e.g. "member.created"
  targetUrl      String   @map("target_url")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plugin TenantPlugin @relation(fields: [tenantPluginId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantPluginId])
  @@index([eventTrigger])
  @@map("plugin_webhooks")
}

// ─────────────────────────────────────────────────────────────
// 33. DEVELOPER PROFILE
// ─────────────────────────────────────────────────────────────
model DeveloperProfile {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  companyName String?  @map("company_name")
  website     String?
  status      String   @default("active") // active | suspended
  payoutEmail String?  @map("payout_email")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets MarketplaceAsset[]
  sandboxTenants SandboxTenant[]

  @@map("developer_profiles")
}

// ─────────────────────────────────────────────────────────────
// 34. MARKETPLACE ASSET
// ─────────────────────────────────────────────────────────────
model MarketplaceAsset {
  id             String   @id @default(uuid())
  developerId    String   @map("developer_id")
  name           String
  description    String?
  type           String   // plugin | theme
  pricingType    String   @map("pricing_type") // free | paid
  price          Float    @default(0.0)
  version        String   @default("1.0.0")
  status         String   @default("draft") // draft | under_review | approved | rejected
  assetConfig    String   @default("{}") @map("asset_config") // JSON string of details/manifest
  revenueSharePct Float    @default(0.70) @map("revenue_share_pct")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  developer   DeveloperProfile @relation(fields: [developerId], references: [id], onDelete: Cascade)
  submissions AssetSubmission[]
  feedbacks   AssetFeedback[]
  purchases   AssetPurchase[]

  @@map("marketplace_assets")
}

// ─────────────────────────────────────────────────────────────
// 35. ASSET SUBMISSION
// ─────────────────────────────────────────────────────────────
model AssetSubmission {
  id          String   @id @default(uuid())
  assetId     String   @map("asset_id")
  version     String
  changelog   String?
  status      String   @default("pending") // pending | approved | rejected
  submittedAt DateTime @default(now()) @map("submitted_at")

  asset   MarketplaceAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  reviews SubmissionReview[]

  @@map("asset_submissions")
}

// ─────────────────────────────────────────────────────────────
// 36. SUBMISSION REVIEW
// ─────────────────────────────────────────────────────────────
model SubmissionReview {
  id           String   @id @default(uuid())
  submissionId String   @map("submission_id")
  reviewerId   String   @map("reviewer_id") // admin User ID
  decision     String   // approved | rejected | changes_requested
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  submission AssetSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("submission_reviews")
}

// ─────────────────────────────────────────────────────────────
// 37. ASSET FEEDBACK / RATINGS
// ─────────────────────────────────────────────────────────────
model AssetFeedback {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  assetId   String   @map("asset_id")
  userId    String   @map("user_id")
  rating    Int      @default(5) // 1 to 5
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset  MarketplaceAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([assetId])
  @@map("asset_feedbacks")
}

// ─────────────────────────────────────────────────────────────
// 38. ASSET PURCHASE
// ─────────────────────────────────────────────────────────────
model AssetPurchase {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  assetId        String   @map("asset_id")
  amountPaid     Float    @map("amount_paid")
  developerShare Float    @map("developer_share")
  platformShare  Float    @map("platform_share")
  status         String   @default("completed") // completed | refunded
  createdAt      DateTime @default(now()) @map("created_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset  MarketplaceAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([assetId])
  @@map("asset_purchases")
}

// ─────────────────────────────────────────────────────────────
// 39. SANDBOX TENANT
// ─────────────────────────────────────────────────────────────
model SandboxTenant {
  id          String   @id @default(uuid())
  developerId String   @map("developer_id")
  tenantId    String   @unique @map("tenant_id")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  developer DeveloperProfile @relation(fields: [developerId], references: [id], onDelete: Cascade)
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([developerId])
  @@map("sandbox_tenants")
}

// ─────────────────────────────────────────────────────────────
// 40. LANGUAGE REGISTRY
// ─────────────────────────────────────────────────────────────
model LanguageRegistry {
  id        String   @id // e.g. "en", "es", "fr", "ar"
  name      String
  direction String   @default("ltr") // ltr | rtl
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  translationKeys TranslationKey[]

  @@map("language_registries")
}

// ─────────────────────────────────────────────────────────────
// 41. TRANSLATION KEY
// ─────────────────────────────────────────────────────────────
model TranslationKey {
  id        String   @id @default(uuid())
  locale    String
  key       String
  value     String
  namespace String   @default("core")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  language LanguageRegistry @relation(fields: [locale], references: [id], onDelete: Cascade)

  @@unique([locale, key, namespace])
  @@map("translation_keys")
}

// ─────────────────────────────────────────────────────────────
// 42. MEDIA CATEGORY
// ─────────────────────────────────────────────────────────────
model MediaCategory {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  slug      String
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   MediaCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children MediaCategory[] @relation("CategoryHierarchy")
  assets   MediaAsset[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([parentId])
  @@map("media_categories")
}

// ─────────────────────────────────────────────────────────────
// 43. MEDIA TAG
// ─────────────────────────────────────────────────────────────
model MediaTag {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  slug      String
  createdAt DateTime @default(now()) @map("created_at")

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assetTags MediaAssetTag[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("media_tags")
}

// ─────────────────────────────────────────────────────────────
// 44. SPEAKER
// ─────────────────────────────────────────────────────────────
model Speaker {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  title     String?  // e.g. "Senior Pastor"
  bio       String?
  photoUrl  String?  @map("photo_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assets MediaAsset[]
  churchServices ChurchService[]
  blogPosts      BlogPost[]

  @@index([tenantId])
  @@map("speakers")
}

// ─────────────────────────────────────────────────────────────
// 45. MEDIA SERIES
// ─────────────────────────────────────────────────────────────
model MediaSeries {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  title         String
  description   String?
  coverImageUrl String?  @map("cover_image_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assets MediaAsset[]

  @@index([tenantId])
  @@map("media_series")
}

// ─────────────────────────────────────────────────────────────
// 46. MEDIA ASSET
// ─────────────────────────────────────────────────────────────
model MediaAsset {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  title           String
  description     String?
  type            String    // video | audio | image | short_clip | document
  providerType    String    @map("provider_type")  // platform_managed | external_link
  providerKey     String?   @map("provider_key")   // youtube | vimeo | s3 | cloudflare_r2
  sourceUrl       String?   @map("source_url")
  thumbnailUrl    String?   @map("thumbnail_url")
  durationSeconds Int?      @map("duration_seconds")
  fileSizeBytes   Int?      @map("file_size_bytes")
  mimeType        String?   @map("mime_type")
  categoryId      String?   @map("category_id")
  seriesId        String?   @map("series_id")
  seriesOrder     Int?      @map("series_order")
  speakerId       String?   @map("speaker_id")
  visibility      String    @default("public")  // public | members_only | leaders_only
  status          String    @default("draft")   // draft | published | archived
  publishedAt     DateTime? @map("published_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  parentAssetId   String?   @map("parent_asset_id")
  clipStartSeconds Int?     @map("clip_start_seconds")
  clipEndSeconds   Int?     @map("clip_end_seconds")

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category MediaCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  series   MediaSeries?   @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  speaker  Speaker?       @relation(fields: [speakerId], references: [id], onDelete: SetNull)
  parentAsset MediaAsset? @relation("AssetClips", fields: [parentAssetId], references: [id], onDelete: Cascade)
  clips    MediaAsset[]   @relation("AssetClips")

  assetTags     MediaAssetTag[]
  playlistItems MediaPlaylistItem[]
  livestreams   Livestream[]
  sermonServices ChurchService[] @relation("SermonMedia")
  audioServices  ChurchService[] @relation("ServiceAudio")
  aiMediaJobs    AiMediaJob[]
  mediaCaptions  MediaCaption[]

  @@index([tenantId])
  @@index([categoryId])
  @@index([seriesId])
  @@index([speakerId])
  @@index([status])
  @@index([type])
  @@map("media_assets")
}

// ─────────────────────────────────────────────────────────────
// 47. MEDIA ASSET TAG (join table)
// ─────────────────────────────────────────────────────────────
model MediaAssetTag {
  id      String @id @default(uuid())
  assetId String @map("asset_id")
  tagId   String @map("tag_id")

  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag   MediaTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([assetId, tagId])
  @@index([assetId])
  @@index([tagId])
  @@map("media_asset_tags")
}

// ─────────────────────────────────────────────────────────────
// 48. MEDIA PLAYLIST
// ─────────────────────────────────────────────────────────────
model MediaPlaylist {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  name          String
  description   String?
  coverImageUrl String?  @map("cover_image_url")
  isPublic      Boolean  @default(true) @map("is_public")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  MediaPlaylistItem[]

  @@index([tenantId])
  @@map("media_playlists")
}

// ─────────────────────────────────────────────────────────────
// 49. MEDIA PLAYLIST ITEM (ordered join table)
// ─────────────────────────────────────────────────────────────
model MediaPlaylistItem {
  id         String @id @default(uuid())
  playlistId String @map("playlist_id")
  assetId    String @map("asset_id")
  order      Int    @default(0)

  playlist MediaPlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  asset    MediaAsset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([playlistId, assetId])
  @@index([playlistId])
  @@index([assetId])
  @@map("media_playlist_items")
}

// ─────────────────────────────────────────────────────────────
// 50. LIVESTREAM
// ─────────────────────────────────────────────────────────────
model Livestream {
  id                 String    @id @default(uuid())
  tenantId           String    @map("tenant_id")
  title              String
  description        String?
  scheduledAt        DateTime? @map("scheduled_at")
  startedAt          DateTime? @map("started_at")
  endedAt            DateTime? @map("ended_at")
  status             String    @default("scheduled") // scheduled | live | ended | archived
  streamKey          String?   @map("stream_key")
  rtmpIngestUrl      String?   @map("rtmp_ingest_url")
  thumbnailUrl       String?   @map("thumbnail_url")
  countdownEnabled   Boolean   @default(true) @map("countdown_enabled")
  chatEnabled        Boolean   @default(true) @map("chat_enabled")
  multiPlatformLinks String    @default("[]") @map("multi_platform_links") // JSON array [{platform, url}]
  replayAssetId      String?   @map("replay_asset_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  replayAsset  MediaAsset? @relation(fields: [replayAssetId], references: [id], onDelete: SetNull)

  chatMessages LivestreamChat[]
  viewers      LivestreamViewer[]
  interactions LivestreamInteraction[]
  churchServices ChurchService[]
  liveTranslationFeeds LiveTranslationFeed[]
  altarCallResponses   AltarCallResponse[]

  @@index([tenantId])
  @@index([status])
  @@index([scheduledAt])
  @@map("livestreams")
}

// ─────────────────────────────────────────────────────────────
// 51. LIVESTREAM CHAT MESSAGE
// ─────────────────────────────────────────────────────────────
model LivestreamChat {
  id            String   @id @default(uuid())
  livestreamId  String   @map("livestream_id")
  tenantId      String   @map("tenant_id")
  userId        String?  @map("user_id")
  displayName   String   @map("display_name")
  message       String
  createdAt     DateTime @default(now()) @map("created_at")

  livestream Livestream @relation(fields: [livestreamId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([livestreamId])
  @@index([tenantId])
  @@map("livestream_chats")
}

// ─────────────────────────────────────────────────────────────
// 52. LIVESTREAM VIEWER SESSION
// ─────────────────────────────────────────────────────────────
model LivestreamViewer {
  id              String    @id @default(uuid())
  livestreamId    String    @map("livestream_id")
  tenantId        String    @map("tenant_id")
  userId          String?   @map("user_id")
  sessionId       String?   @map("session_id")
  joinedAt        DateTime  @default(now()) @map("joined_at")
  leftAt          DateTime? @map("left_at")
  durationSeconds Int?      @map("duration_seconds")

  livestream Livestream @relation(fields: [livestreamId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([livestreamId])
  @@index([tenantId])
  @@map("livestream_viewers")
}

// ─────────────────────────────────────────────────────────────
// 53. LIVESTREAM INTERACTION
// ─────────────────────────────────────────────────────────────
model LivestreamInteraction {
  id           String   @id @default(uuid())
  livestreamId String   @map("livestream_id")
  tenantId     String   @map("tenant_id")
  userId       String?  @map("user_id")
  type         String   // prayer_request | salvation_response | note | giving_click
  content      String?
  createdAt    DateTime @default(now()) @map("created_at")

  livestream Livestream @relation(fields: [livestreamId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([livestreamId])
  @@index([tenantId])
  @@index([type])
  @@map("livestream_interactions")
}

// ─────────────────────────────────────────────────────────────
// 54. CHURCH SERVICE
// ─────────────────────────────────────────────────────────────
model ChurchService {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  title           String
  serviceType     String    @map("service_type") // sunday | midweek | prayer | communion | healing | thanksgiving | other
  serviceDate     DateTime  @map("service_date")
  description     String?
  notes           String?   // official outline / summary
  thumbnailUrl    String?   @map("thumbnail_url")
  speakerId       String?   @map("speaker_id")
  sermonMediaId   String?   @map("sermon_media_id")
  serviceAudioId  String?   @map("service_audio_id")
  livestreamId    String?   @map("livestream_id")
  attendanceCount Int?      @map("attendance_count")
  givingTotal     Float?    @map("giving_total")
  salvationCount  Int?      @map("salvation_count")
  status          String    @default("draft") // draft | published | archived
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  speaker      Speaker?    @relation(fields: [speakerId], references: [id], onDelete: SetNull)
  sermonMedia  MediaAsset? @relation("SermonMedia", fields: [sermonMediaId], references: [id], onDelete: SetNull)
  serviceAudio MediaAsset? @relation("ServiceAudio", fields: [serviceAudioId], references: [id], onDelete: SetNull)
  livestream   Livestream? @relation(fields: [livestreamId], references: [id], onDelete: SetNull)

  scriptures   ServiceScripture[]
  attachments  ServiceAttachment[]

  @@index([tenantId])
  @@index([serviceType])
  @@index([serviceDate])
  @@index([speakerId])
  @@index([status])
  @@map("church_services")
}

// ─────────────────────────────────────────────────────────────
// 55. SERVICE SCRIPTURE REFERENCE
// ─────────────────────────────────────────────────────────────
model ServiceScripture {
  id        String @id @default(uuid())
  serviceId String @map("service_id")
  reference String // e.g. "John 3:16", "Romans 8:28"
  order     Int    @default(0)

  service ChurchService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("service_scriptures")
}

// ─────────────────────────────────────────────────────────────
// 56. SERVICE ATTACHMENT
// ─────────────────────────────────────────────────────────────
model ServiceAttachment {
  id        String   @id @default(uuid())
  serviceId String   @map("service_id")
  title     String
  fileUrl   String   @map("file_url")
  fileType  String?  @map("file_type") // pdf | docx | pptx
  createdAt DateTime @default(now()) @map("created_at")

  service ChurchService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("service_attachments")
}

// ─────────────────────────────────────────────────────────────
// 57. BLOG CATEGORY
// ─────────────────────────────────────────────────────────────
model BlogCategory {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  slug        String
  description String?
  parentId    String?  @map("parent_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   BlogCategory?   @relation("BlogCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children BlogCategory[]  @relation("BlogCategoryHierarchy")
  posts    BlogPost[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([parentId])
  @@map("blog_categories")
}

// ─────────────────────────────────────────────────────────────
// 58. BLOG TAG
// ─────────────────────────────────────────────────────────────
model BlogTag {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  slug      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  posts  BlogPostTag[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("blog_tags")
}

// ─────────────────────────────────────────────────────────────
// 59. BLOG POST
// ─────────────────────────────────────────────────────────────
model BlogPost {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  title         String
  slug          String
  content       String    // HTML/Markdown/JSON body
  excerpt       String?
  postType      String    @map("post_type") // devotional | news | article | other
  status        String    @default("draft") // draft | published | archived
  publishedAt   DateTime? @map("published_at")
  coverImageUrl String?   @map("cover_image_url")
  authorId      String?   @map("author_id")
  categoryId    String?   @map("category_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author   Speaker?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
  category BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  tags       BlogPostTag[]
  scriptures BlogPostScripture[]
  comments   BlogPostComment[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([categoryId])
  @@index([authorId])
  @@index([status])
  @@index([postType])
  @@map("blog_posts")
}

// ─────────────────────────────────────────────────────────────
// 60. BLOG POST TAG (Join table)
// ─────────────────────────────────────────────────────────────
model BlogPostTag {
  id     String @id @default(uuid())
  postId String @map("post_id")
  tagId  String @map("tag_id")

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId])
  @@index([postId])
  @@index([tagId])
  @@map("blog_post_tags")
}

// ─────────────────────────────────────────────────────────────
// 61. BLOG POST SCRIPTURE
// ─────────────────────────────────────────────────────────────
model BlogPostScripture {
  id        String @id @default(uuid())
  postId    String @map("post_id")
  reference String // e.g. "Romans 12:1-2"
  order     Int    @default(0)

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("blog_post_scriptures")
}

// ─────────────────────────────────────────────────────────────
// 62. BLOG POST COMMENT
// ─────────────────────────────────────────────────────────────
model BlogPostComment {
  id          String   @id @default(uuid())
  postId      String   @map("post_id")
  tenantId    String   @map("tenant_id")
  userId      String?  @map("user_id")
  displayName String   @map("display_name")
  email       String?
  content     String
  status      String   @default("pending") // pending | approved | spam
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tenant Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([postId])
  @@index([tenantId])
  @@index([status])
  @@map("blog_post_comments")
}

// ─────────────────────────────────────────────────────────────
// 63. LIBRARY CATEGORY
// ─────────────────────────────────────────────────────────────
model LibraryCategory {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  slug        String
  description String?
  parentId    String?  @map("parent_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   LibraryCategory?  @relation("LibraryCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children LibraryCategory[] @relation("LibraryCategoryHierarchy")
  resources LibraryResource[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([parentId])
  @@map("library_categories")
}

// ─────────────────────────────────────────────────────────────
// 64. LIBRARY RESOURCE
// ─────────────────────────────────────────────────────────────
model LibraryResource {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  title         String
  slug          String
  description   String?
  author        String?
  fileUrl       String   @map("file_url")
  fileSize      Int?     @map("file_size") // in bytes
  fileType      String?  @map("file_type") // pdf | epub | docx | pptx | other
  coverImageUrl String?  @map("cover_image_url")
  pricingType   String   @default("free") @map("pricing_type") // free | paid
  price         Float    @default(0.0)
  visibility    String   @default("public") // public | members_only | leaders_only
  status        String   @default("draft") // draft | published | archived
  downloadCount Int      @default(0) @map("download_count")
  categoryId    String?  @map("category_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category LibraryCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  purchases LibraryPurchase[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([categoryId])
  @@index([status])
  @@map("library_resources")
}

// ─────────────────────────────────────────────────────────────
// 65. LIBRARY PURCHASE
// ─────────────────────────────────────────────────────────────
model LibraryPurchase {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  resourceId String   @map("resource_id")
  userId     String   @map("user_id")
  amountPaid Float    @map("amount_paid")
  createdAt  DateTime @default(now()) @map("created_at")

  resource LibraryResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([resourceId])
  @@index([userId])
  @@map("library_purchases")
}

// ─────────────────────────────────────────────────────────────
// 66. PODCAST SHOW
// ─────────────────────────────────────────────────────────────
model PodcastShow {
