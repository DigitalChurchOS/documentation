model GroupType {
  id                  String   @id @default(uuid())
  tenantId            String   @map("tenant_id")
  name                String   // e.g. "Master Cell", "Super Cell", "Cell"
  tierLevel           Int      @map("tier_level") // 1 (Master), 2 (Super Cell), 3 (Cell)
  maxMembersThreshold Int      @default(25) @map("max_members_threshold")
  nestedCellsThreshold Int     @default(25) @map("nested_cells_threshold")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groups Group[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("group_types")
}

model Group {
  id                 String   @id @default(uuid())
  tenantId           String   @map("tenant_id")
  parentId           String?  @map("parent_id")
  groupTypeId        String   @map("group_type_id")
  name               String
  description        String?
  status             String   @default("active") // active | merged | disbanded
  leaderId           String?  @map("leader_id")
  coLeaderId         String?  @map("co_leader_id")
  hostId             String?  @map("host_id")
  locationGeocoding  String?  @map("location_geocoding") // JSON-string: {lat, lng, address}
  onlineMeetingUrl   String?  @map("online_meeting_url")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groupType   GroupType   @relation(fields: [groupTypeId], references: [id], onDelete: Cascade)
  parent      Group?      @relation("GroupHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Group[]     @relation("GroupHierarchy")
  leader      Member?     @relation("GroupLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  coLeader    Member?     @relation("GroupCoLeader", fields: [coLeaderId], references: [id], onDelete: SetNull)
  host        Member?     @relation("GroupHost", fields: [hostId], references: [id], onDelete: SetNull)

  members     GroupMember[]
  meetings    GroupMeeting[]
  inviteLinks GroupInviteLink[]
  noticeBoard GroupNoticeBoard?

  @@index([tenantId])
  @@index([parentId])
  @@index([groupTypeId])
  @@map("groups")
}

