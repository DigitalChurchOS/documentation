# Churchtell - Environment Configuration Template

# Network configuration
PORT=3000
NODE_ENV=development

# Database connection URL
DATABASE_URL="file:./prisma/dev.db"

# Security keys (Ensure these are replaced with strong, cryptographically random values in production)
JWT_SECRET="replace-with-a-secure-random-jwt-secret-key-32-chars-minimum"
VAULT_SECRET="replace-with-a-secure-random-vault-encryption-key"
