{
  "name": "churchos",
  "version": "1.0.0",
  "description": "This repository contains the planning and architecture documentation for Churchtell before main project development begins.",
  "main": "index.js",
  "scripts": {
    "build": "node scripts/build-cloudflare-assets.js",
    "build:api": "npx prisma generate && npx tsc",
    "deploy": "wrangler deploy --config wrangler.toml",
    "deploy:dry": "wrangler deploy --config wrangler.toml --dry-run",
    "deploy:api": "wrangler deploy --config wrangler.api.toml",
    "deploy:api:dry": "wrangler deploy --config wrangler.api.toml --dry-run",
    "deploy:all": "npm run deploy:api && npm run deploy",
    "dev": "npx ts-node --files src/server.ts",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "npx ts-node src/seed.ts",
    "db:reset": "npx prisma migrate reset --force",
    "test": "npx jest --forceExit --detectOpenHandles"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DigitalChurchOS/documentation.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/DigitalChurchOS/documentation/issues"
  },
  "homepage": "https://github.com/DigitalChurchOS/documentation#readme",
  "dependencies": {
    "@libsql/client": "^0.8.1",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-d1": "^7.8.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "wrangler": "^3.114.17"
  }
}
